# Primjer env varijabli za /api/send-order-emails.
# Stvarne vrijednosti postavljaju se lokalno u .env
# i u Vercel Dashboardu.

# Gmail račun koji šalje poruke
GMAIL_USER=your-email@gmail.com

# Gmail App Password, ne obična lozinka
GMAIL_APP_PASSWORD=your-app-password

# Adresa vlasnika trgovine koja prima narudžbe
OWNER_EMAIL=owner@example.com